      "regex": "^https?://(?:[a-zA-Z0-9.-]+\\.)?upscrolled\\.com(?:/[a-z]{2})?(?:/(?:profile|u|user|@)?/([a-zA-Z0-9_.-]{1,100}))?/?(?:\\?.*)?$",
