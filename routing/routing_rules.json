      "phantomConfig": {
        "waitForSelector": "article, [class*='post'], [class*='card'], [class*='video'], [class*='feed'], [class*='item'], main",
        "extractJS": "(function(){ var username = '$1'; var items = Array.from(document.querySelectorAll('article, [class*=\"post\"], [class*=\"card\"], [class*=\"video\"], [class*=\"item\"]')).filter(function(el){ return el.querySelector('a[href]') !== null; }).slice(0, 30).map(function(el){ var link = el.querySelector('a[href]'); var img = el.querySelector('img, video'); var title = el.querySelector('h1,h2,h3,h4,[class*=\"title\"],[class*=\"heading\"]'); var desc = el.querySelector('p,[class*=\"desc\"],[class*=\"caption\"],[class*=\"body\"]'); return { title: (title && title.innerText.trim()) || (link && link.innerText.trim()) || 'Post', url: link ? (link.href.startsWith('http') ? link.href : window.location.origin + link.getAttribute('href')) : window.location.href, imageUrl: img ? (img.src || img.getAttribute('poster') || '') : '', snippet: desc ? desc.innerText.trim().substring(0,300) : '', author: username || (document.querySelector('[class*=\"author\"],[class*=\"username\"]') || {innerText:''}).innerText.trim() }; }); return items.length > 0 ? items : [{ title: 'Feed loaded', url: window.location.href, imageUrl: '', snippet: document.title }]; })()"
      }
